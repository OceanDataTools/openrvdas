; openrvdas supervisor base config - generated by Ansible
; Do not edit by hand; re-run the Ansible playbook to regenerate.

{% if ansible_facts['os_family'] != 'Darwin' %}
; Override default socket permissions so {{ rvdas_user }} can run supervisorctl
[unix_http_server]
file={{ supervisor_sock }}
chmod=0770
chown=nobody:{{ rvdas_group }}

{% endif %}
{% if supervisord_webinterface %}
[inet_http_server]
port=*:{{ supervisord_webinterface_port }}
{% if supervisord_webinterface_auth %}
username={{ supervisord_webinterface_user }}
password={SHA}{{ supervisord_webinterface_pass | hash('sha1') }}
{% endif %}

{% endif %}
